{
  "name": "@noteplanco/noteplan-mcp",
  "version": "1.1.27",
  "description": "MCP server for NotePlan note and task management",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "noteplan-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "docs/",
    "scripts/calendar-helper",
    "scripts/reminders-helper",
    "README.md"
  ],
  "os": [
    "darwin"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "npm run build:swift && tsc",
    "build:swift": "bash scripts/build-helpers.sh",
    "build:ts": "tsc",
    "smoke:workflow": "node scripts/workflow-smoke.mjs",
    "start": "node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "preflight:signed-helpers": "bash scripts/preflight-signed-helpers.sh",
    "prepublishOnly": "npm run build && npm run preflight:signed-helpers"
  },
  "keywords": [
    "mcp",
    "noteplan",
    "model-context-protocol",
    "notes",
    "tasks",
    "calendar",
    "reminders",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/NotePlan/noteplan-mcp.git"
  },
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "fuse.js": "^7.1.0",
    "sql.js": "^1.11.0",
    "uuid": "^9.0.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/uuid": "^9.0.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
