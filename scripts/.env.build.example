# Build configuration for signed + notarized release builds.
#
# Copy to scripts/.env.build (which is gitignored) and fill in the real
# values. The build script (scripts/build-helpers.sh) sources this file
# automatically if it exists.
#
# All variables are optional — without them, `npm run build` falls back
# to ad-hoc signing (works locally, blocked on managed Macs).

# Apple Developer Team ID. Used to find your Developer ID Application
# certificate in the login keychain by team. Public-but-sensitive (it
# appears in every signed binary you ship), so we keep it out of git.
NP_TEAM_ID=

# Name of the notarytool credential profile in your login keychain.
# Set up once with:
#   xcrun notarytool store-credentials <profile-name> \
#     --apple-id "<your-apple-id-email>" \
#     --team-id "<NP_TEAM_ID>" \
#     --password "<app-specific-password from appleid.apple.com>"
NP_NOTARIZE_PROFILE=
